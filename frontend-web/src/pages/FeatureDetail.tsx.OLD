interface Feature {
  title: string;
  description: string;
  icon: any;
}

interface Benefit {
  title: string;
  description: string;
  metric?: string;
}

interface ModuleContent {
  id: string;
  title: string;
  subtitle: string;
  description: string;
  heroGradient: string;
  icon: any;
  mainFeatures: Feature[];
  keyBenefits: Benefit[];
  differentiators: string[];
  useCases: {
    title: string;
    description: string;
    image: string;
  }[];
  stats: {
    value: string;
    label: string;
  }[];
}

