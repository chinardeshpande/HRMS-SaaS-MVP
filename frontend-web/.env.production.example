# ==================================
# FRONTEND PRODUCTION ENVIRONMENT
# ==================================
# Copy this file to .env.production and fill in actual values
# These variables are embedded at BUILD TIME

# ==================================
# API CONFIGURATION
# ==================================
# Backend API URL (must match your production backend)
VITE_API_URL=https://api.hrms-app.com/api

# WebSocket URL (for Socket.IO connections)
VITE_SOCKET_URL=https://api.hrms-app.com

# ==================================
# APPLICATION CONFIGURATION
# ==================================
VITE_APP_NAME=HRMS App
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=production

# ==================================
# FEATURE FLAGS
# ==================================
# Enable/disable features in production
VITE_ENABLE_DEBUG=false
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_TRACKING=true

# ==================================
# THIRD-PARTY SERVICES
# ==================================
# Google Analytics (optional)
VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Sentry for error tracking (optional)
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
VITE_SENTRY_ENVIRONMENT=production

# ==================================
# STORAGE CONFIGURATION
# ==================================
# CDN URL for static assets (if using)
VITE_CDN_URL=https://cdn.hrms-app.com

# File upload size limits (in bytes)
VITE_MAX_FILE_SIZE=10485760

# ==================================
# SECURITY
# ==================================
# Content Security Policy settings
VITE_CSP_ENABLED=true

# ==================================
# BUILD CONFIGURATION
# ==================================
# Base URL for the app (usually /)
VITE_BASE_URL=/

# Public path for assets
VITE_PUBLIC_PATH=/
