# ==================================
# PRODUCTION ENVIRONMENT VARIABLES
# ==================================
# Copy this file to .env.production and fill in actual values
# NEVER commit .env.production to version control

# ==================================
# SERVER CONFIGURATION
# ==================================
NODE_ENV=production
PORT=3000
API_VERSION=v1

# Backend URL (used for CORS and callbacks)
BACKEND_URL=https://api.hrms-app.com

# Frontend URL (used for CORS and redirects)
FRONTEND_URL=https://hrms-app.com

# ==================================
# DATABASE CONFIGURATION
# ==================================
# Use DigitalOcean Managed Database connection details
DB_HOST=your-db-host.db.ondigitalocean.com
DB_PORT=25060
DB_NAME=hrms_saas_prod
DB_USER=doadmin
DB_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD

# Enable SSL for database connection
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true

# Connection pool settings
DB_POOL_MIN=2
DB_POOL_MAX=10

# ==================================
# JWT CONFIGURATION
# ==================================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_64_CHAR_RANDOM_STRING_GENERATE_NEW_ONE
JWT_EXPIRY=24h
JWT_REFRESH_SECRET=CHANGE_THIS_TO_DIFFERENT_64_CHAR_RANDOM_STRING
JWT_REFRESH_EXPIRY=7d

# ==================================
# EMAIL CONFIGURATION
# ==================================
# Use a transactional email service (SendGrid, Mailgun, AWS SES, etc.)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASSWORD=YOUR_SENDGRID_API_KEY
SMTP_FROM=noreply@hrms-app.com
SMTP_FROM_NAME=HRMS App

# ==================================
# FILE UPLOAD CONFIGURATION
# ==================================
# Use cloud storage in production (S3, DigitalOcean Spaces, etc.)
STORAGE_TYPE=s3
# For DigitalOcean Spaces (S3-compatible)
S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
S3_REGION=nyc3
S3_BUCKET=hrms-app-uploads
S3_ACCESS_KEY_ID=YOUR_SPACES_ACCESS_KEY
S3_SECRET_ACCESS_KEY=YOUR_SPACES_SECRET_KEY
S3_PUBLIC_URL=https://hrms-app-uploads.nyc3.digitaloceanspaces.com

# Fallback local storage (for development)
UPLOAD_DIR=/var/www/hrms-app/uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,doc,docx,xls,xlsx

# ==================================
# RATE LIMITING
# ==================================
# Stricter limits for production
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MS=900000

# ==================================
# CORS CONFIGURATION
# ==================================
# Comma-separated list of allowed origins
CORS_ORIGIN=https://hrms-app.com,https://www.hrms-app.com
CORS_CREDENTIALS=true

# ==================================
# LOGGING
# ==================================
LOG_LEVEL=info
LOG_FILE=/var/www/hrms-app/logs/app.log
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# External logging service (optional)
LOG_SERVICE=papertrail
PAPERTRAIL_HOST=logs.papertrailapp.com
PAPERTRAIL_PORT=12345

# ==================================
# MULTI-TENANCY
# ==================================
TENANT_ID_HEADER=X-Tenant-ID
SUBDOMAIN_ENABLED=false
DEFAULT_TENANT_ID=1

# ==================================
# FEATURE FLAGS
# ==================================
ENABLE_SWAGGER=false
ENABLE_AUDIT_LOG=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false

# ==================================
# SECURITY
# ==================================
# Enable security headers
HELMET_ENABLED=true

# Trust proxy (for Nginx reverse proxy)
TRUST_PROXY=true

# Session secret
SESSION_SECRET=CHANGE_THIS_TO_ANOTHER_64_CHAR_RANDOM_STRING

# ==================================
# REDIS CONFIGURATION (Optional)
# ==================================
# For session storage and caching
REDIS_ENABLED=false
REDIS_HOST=your-redis-host.db.ondigitalocean.com
REDIS_PORT=25061
REDIS_PASSWORD=CHANGE_THIS
REDIS_TLS=true

# ==================================
# MONITORING & OBSERVABILITY
# ==================================
# Sentry for error tracking (optional)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Application insights (optional)
APP_INSIGHTS_KEY=your-app-insights-key

# ==================================
# WEBSOCKET CONFIGURATION
# ==================================
# Socket.IO settings for chat and real-time features
WEBSOCKET_CORS_ORIGIN=https://hrms-app.com,https://www.hrms-app.com
WEBSOCKET_PATH=/socket.io

# ==================================
# BACKUP CONFIGURATION
# ==================================
# Automated backup settings
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=hrms-app-backups

# ==================================
# EXTERNAL INTEGRATIONS
# ==================================
# Add any third-party API keys here

# Google OAuth (if using)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Slack notifications (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ==================================
# DEPLOYMENT INFO
# ==================================
# Auto-populated by CI/CD
DEPLOY_VERSION=1.0.0
DEPLOY_COMMIT_SHA=
DEPLOY_TIMESTAMP=
DEPLOY_ENVIRONMENT=production
